{
    "name": "cms-backend",
    "version": "1.0.0",
    "description": "",
    "main": "dist/app.js",
    "imports": {
        "#controllers": {
            "dev": "./src/controllers/index.ts",
            "default": "./dist/controllers/index.js"
        },
        "#middlewares": {
            "dev": "./src/middlewares/index.ts",
            "default": "./dist/middlewares/index.js"
        },
        "#models": {
            "dev": "./src/models/index.ts",
            "default": "./dist/models/index.js"
        },
        "#routes": {
            "dev": "./src/routes/index.ts",
            "default": "./dist/routes/index.js"
        },
        "#schemas": {
            "dev": "./src/schemas/index.ts",
            "default": "./dist/schemas/index.js"
        },
        "#config": {
            "dev": "./src/config/index.ts",
            "default": "./dist/config/index.js"
        },
        "#utils": {
            "dev": "./src/utils/index.ts",
            "default": "./dist/utils/index.js"
        },
        "#services": {
            "dev": "./src/services/index.ts",
            "default": "./dist/services/index.js"
        },
        "#types": {
            "dev": "./src/types/index.ts",
            "default": "./src/types/index.js"
        }
    },
    "scripts": {
        "dev": "node --watch --conditions dev --env-file=.env src/server.ts",
        "seed": "node --conditions dev --env-file=.env src/scripts/seed.ts",
        "prebuild": "rm -rf dist",
        "build": "tsc",
        "prestart": "npm run build",
        "start": "node --env-file=.env dist/app.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "module",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1053.0",
        "@aws-sdk/s3-request-presigner": "^3.1053.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/jsonwebtoken": "^9.0.10",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.6.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^5.1.3",
        "@types/node": "^25.9.1",
        "typescript": "^6.0.3"
    }
}
